# EditorConfig is awesome: https://EditorConfig.org/

# Top-most EditorConfig file
root = true

[*]
# Indentation and spacing
indent_style = space
indent_size = 2
tab_width = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Newline format
end_of_line = lf

# Character encoding
charset = utf-8

# Maximum line length (optional, but a common practice)
max_line_length = 120

# HTML and CSS specific settings
[*.{html,css}]
indent_size = 4

# Markdown specific settings
[*.md]
trim_trailing_whitespace = false
